<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="boundary.FormVisualizzaDisponibilita">
  <grid id="root" binding="visualizzaDisponibilitaPanel" layout-manager="GridLayoutManager" row-count="7" column-count="2" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
    <margin top="15" left="15" bottom="15" right="15"/>
    <constraints>
      <xy x="20" y="20" width="460" height="420"/>
    </constraints>
    <properties>
      <preferredSize width="460" height="420"/>
    </properties>
    <border type="none"/>
    <children>
      <component id="lblSpec" class="javax.swing.JLabel">
        <constraints>
          <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <text value="Specializzazione:"/>
        </properties>
      </component>
      <component id="cmbSpec" class="javax.swing.JComboBox" binding="comboSpecializzazione" default-binding="true">
        <constraints>
          <grid row="0" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="2" anchor="8" fill="1" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties/>
      </component>
      <component id="lblMedico" class="javax.swing.JLabel">
        <constraints>
          <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <text value="Medico:"/>
        </properties>
      </component>
      <component id="cmbMedico" class="javax.swing.JComboBox" binding="comboMedico" default-binding="true">
        <constraints>
          <grid row="1" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="2" anchor="8" fill="1" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties/>
      </component>
      <component id="lblData" class="javax.swing.JLabel">
        <constraints>
          <grid row="2" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <text value="Data:"/>
        </properties>
      </component>
      <component id="dtData" class="com.toedter.calendar.JDateChooser" binding="selettoreData" custom-create="true" default-binding="true">
        <constraints>
          <grid row="2" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="8" fill="1" indent="0" use-parent-layout="false">
            <preferred-size width="220" height="-1"/>
          </grid>
        </constraints>
        <properties/>
      </component>
      <component id="btnCerca" class="javax.swing.JButton" binding="mostraButton" default-binding="true">
        <constraints>
          <grid row="3" column="0" row-span="1" col-span="2" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <text value="Mostra disponibilità"/>
        </properties>
      </component>
      <component id="lblFasce" class="javax.swing.JLabel">
        <constraints>
          <grid row="4" column="0" row-span="1" col-span="2" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <text value="Fasce libere:"/>
        </properties>
      </component>
      <scrollpane id="spLista">
        <constraints>
          <grid row="5" column="0" row-span="1" col-span="2" vsize-policy="7" hsize-policy="7" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties/>
        <border type="none"/>
        <children>
          <component id="lista" class="javax.swing.JList" binding="listaFasce" default-binding="true">
            <constraints/>
            <properties/>
          </component>
        </children>
      </scrollpane>
      <component id="lblEsito" class="javax.swing.JLabel" binding="etichettaEsito">
        <constraints>
          <grid row="6" column="0" row-span="1" col-span="2" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <text value=" "/>
        </properties>
      </component>
    </children>
  </grid>
</form>
